@model IEnumerable<KomuNect.Models.Announcement>
@{
    ViewData["Title"] = "Barangay Announcements";
    string role = ViewBag.Role ?? "resident";
}

<div class="p-8 max-w-5xl mx-auto min-h-screen">

    <div class="flex justify-between items-end mb-8 border-b border-gray-200 pb-4">
        <div>
            <h1 class="text-3xl font-black text-[#003B5A] italic tracking-tight">Community <span class="text-[#2D7DA5]">Announcements</span></h1>
            <p class="text-gray-500 text-sm mt-1">Stay updated with the latest barangay news and events.</p>
        </div>

        @if (role == "admin")
        {
            <a href="/Announcement/Create" class="bg-[#003B5A] text-white font-bold py-2 px-6 rounded-lg shadow hover:bg-[#2D7DA5] transition flex items-center gap-2">
                <i class="fa-solid fa-plus"></i> Post Announcement
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6 font-bold text-sm">
            @TempData["Success"]
        </div>
    }

    <div class="space-y-6">

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
                <i class="fa-regular fa-bell-slash text-4xl text-gray-300 mb-3"></i>
                <p class="text-gray-500 font-medium">No announcements posted yet.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 relative group">

                    @if (role == "admin")
                    {
                        <div class="absolute top-4 right-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <a href="/Announcement/Edit/@item.Id" class="bg-blue-100 text-blue-700 p-2 rounded hover:bg-blue-200 transition" title="Edit">
                                <i class="fa-solid fa-pen text-xs"></i>
                            </a>
                            <form action="/Announcement/Delete/@item.Id" method="POST" onsubmit="return confirm('Are you sure you want to delete this?');">
                                <button type="submit" class="bg-red-100 text-red-700 p-2 rounded hover:bg-red-200 transition" title="Delete">
                                    <i class="fa-solid fa-trash text-xs"></i>
                                </button>
                            </form>
                        </div>
                    }

                    <div class="p-6">
                        <div class="flex items-start justify-between mb-3">
                            <h2 class="text-xl font-bold text-[#003B5A]">@item.Title</h2>
                        </div>

                        <p class="text-gray-600 text-sm mb-5 whitespace-pre-line">@item.Content</p>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 bg-gray-50 p-4 rounded-lg border border-gray-100">
                            <div>
                                @if (item.EventDate.HasValue)
                                {
                                    <p class="text-xs text-gray-600 mb-1"><i class="fa-regular fa-calendar text-[#2D7DA5] mr-2 w-4"></i> <strong>Date:</strong> @item.EventDate.Value.ToString("MMMM dd, yyyy")</p>
                                }
                                @if (!string.IsNullOrEmpty(item.Location))
                                {
                                    <p class="text-xs text-gray-600"><i class="fa-solid fa-location-dot text-[#2D7DA5] mr-2 w-4"></i> <strong>Location:</strong> @item.Location</p>
                                }
                            </div>

                            <div class="md:text-right flex flex-col justify-end">
                                <p class="text-[10px] text-gray-400 font-medium">Posted: @item.PostedAt.ToString("MMM dd, yyyy - hh:mm tt")</p>
                                @if (item.EditedAt.HasValue)
                                {
                                    <p class="text-[10px] text-gray-400 font-medium italic mt-0.5">Edited: @item.EditedAt.Value.ToString("MMM dd, yyyy - hh:mm tt")</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>