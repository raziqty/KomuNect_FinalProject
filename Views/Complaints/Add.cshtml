@model KomuNect_Demo.Models.ViewModels.AddComplaintViewModel
@{
    ViewData["Title"] = "File a Complaint";
}

<div class="p-8 max-w-3xl mx-auto min-h-screen">

    <div class="mb-6">
        <a href="/Complaints/List" class="text-sm text-gray-500 hover:text-[#003B5A] transition">
            <i class="fa-solid fa-arrow-left mr-1"></i> Back to Complaints
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-lg p-8 border border-gray-100">
        <h2 class="text-2xl font-bold text-red-700 mb-2">File a Complaint or Concern</h2>
        <p class="text-gray-500 text-sm mb-6">Your concern will be securely sent to the barangay administration for review.</p>

        <div asp-validation-summary="All" class="text-red-500 text-xs font-bold mb-4 empty:hidden"></div>

        <form asp-controller="Complaints" asp-action="Add" method="POST" class="space-y-5">

            <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">Subject / Type of Concern <span class="text-red-500">*</span></label>
                <select asp-for="SubjectId" asp-items="Model.Subjects" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-red-700 focus:ring-1 focus:ring-red-700 outline-none transition bg-white cursor-pointer">
                    <option value="">-- Select a Subject --</option>
                </select>
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">Detailed Description <span class="text-red-500">*</span></label>
                <textarea asp-for="Details" rows="6" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-red-700 focus:ring-1 focus:ring-red-700 outline-none transition" placeholder="Please describe the incident, location, and any other relevant details..."></textarea>
            </div>

            <div class="pt-4 mt-2 border-t border-gray-100 flex justify-end">
                <button type="submit" class="bg-red-700 text-white font-bold py-3 px-8 rounded-lg shadow-md hover:bg-red-800 transition flex items-center gap-2">
                    <i class="fa-solid fa-paper-plane"></i> Submit Complaint
                </button>
            </div>
        </form>
    </div>
</div>