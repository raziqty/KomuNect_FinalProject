@model KomuNect_Demo.Models.ViewModels.EditComplaintViewModel
@{
    ViewData["Title"] = "Update Complaint Status";
}

<div class="p-8 max-w-3xl mx-auto min-h-screen">

    <div class="mb-6">
        <a href="/Complaints/List" class="text-sm text-gray-500 hover:text-[#003B5A] transition">
            <i class="fa-solid fa-arrow-left mr-1"></i> Back to Dashboard
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-lg p-8 border border-gray-100">
        <h2 class="text-2xl font-bold text-[#003B5A] mb-2">Update Complaint Record</h2>
        <p class="text-gray-500 text-sm mb-6">Change the status of the resident's concern and leave an official response.</p>

        <div asp-validation-summary="All" class="text-red-500 text-xs font-bold mb-4 empty:hidden"></div>

        <form asp-controller="Complaints" asp-action="Edit" method="POST" class="space-y-5">

            <!-- CRITICAL: Hidden ID so the backend knows exactly WHICH complaint to update -->
            <input type="hidden" asp-for="Id" />

            <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">Current Status <span class="text-red-500">*</span></label>
                <!-- This C# helper automatically turns his ComplaintStatus Enum into a dropdown! -->
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<KomuNect_Demo.Models.Entities.ComplaintStatus>()" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#003B5A] focus:ring-1 focus:ring-[#003B5A] outline-none transition bg-white cursor-pointer">
                </select>
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">Admin Response / Note</label>
                <textarea asp-for="AdminNote" rows="5" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#003B5A] focus:ring-1 focus:ring-[#003B5A] outline-none transition" placeholder="Write an official response. The resident will see this on their dashboard..."></textarea>
            </div>

            <div class="pt-4 mt-2 border-t border-gray-100 flex justify-end">
                <button type="submit" class="bg-[#003B5A] text-white font-bold py-3 px-8 rounded-lg shadow-md hover:bg-[#2D7DA5] transition">
                    Save Updates
                </button>
            </div>
        </form>
    </div>
</div>