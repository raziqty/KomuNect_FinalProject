@{
    ViewData["Title"] = "Select Portal";
    string currentMode = ViewBag.Mode ?? "login";
    string routePrefix = currentMode == "login" ? "/Auth/Login" : "/Auth/Signup";
}

<section class="relative min-h-screen bg-cover bg-center flex items-center justify-center py-12" style="background-image: url('/images/barangay.jpg');">

    <div class="absolute inset-0 bg-[#003B5A]/90"></div>

    <div class="relative z-10 w-full max-w-5xl px-6">

        <div class="text-center mb-12">
            <img src="/images/Logo.jpg" alt="KomuNect Logo" class="h-12 mx-auto mb-6 rounded-full shadow-lg border-2 border-white/20">

            <h2 class="text-white text-3xl md:text-5xl font-bold mb-3 tracking-tight">
                Select Portal
            </h2>
            <p class="text-[#C1E7FF] opacity-80 text-lg font-medium">
                Please select your role to proceed to the system.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">

            <!-- 1. RESIDENT CARD (Always active) -->
            <a href="@routePrefix?role=resident" class="group relative bg-white/10 backdrop-blur-md border border-white/20 rounded-3xl p-10 text-center transition-all duration-300 hover:bg-[#C1E7FF] hover:scale-105 hover:shadow-[0_0_40px_rgba(193,231,255,0.3)] cursor-pointer">

                <div class="absolute top-0 left-0 right-0 -mt-3 flex justify-center">
                    <span class="bg-[#2D7DA5] text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-widest shadow-lg group-hover:bg-[#003B5A] transition">
                        Resident Access
                    </span>
                </div>

                <div class="bg-white/10 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-8 group-hover:bg-[#003B5A] transition duration-300 border border-white/10 group-hover:border-transparent">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-[#C1E7FF] group-hover:text-white transition duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                </div>

                <h3 class="font-sans font-black italic tracking-tighter text-4xl text-white mb-3 group-hover:text-[#003B5A] transition duration-300">
                    Resident
                </h3>

                <p class="text-[#C1E7FF]/70 text-sm leading-relaxed group-hover:text-[#003B5A]/80 transition duration-300 px-4">
                    Access barangay services, request certificates, file complaints, and view community announcements.
                </p>

                <div class="mt-6 inline-block border-b-2 border-[#C1E7FF]/30 group-hover:border-[#003B5A] pb-1 text-[#C1E7FF] group-hover:text-[#003B5A] text-xs font-bold uppercase tracking-wider transition">
                    Proceed &rarr;
                </div>
            </a>


            <!-- 2. ADMIN CARD (Conditional Logic) -->
            @if (currentMode == "register")
            {
                <!-- DISABLED STATE (When Registering) -->
                <div class="relative bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl p-10 text-center opacity-60 cursor-not-allowed">

                    <div class="absolute top-0 left-0 right-0 -mt-3 flex justify-center">
                        <span class="bg-gray-600 text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-widest shadow-lg">
                            Administrative
                        </span>
                    </div>

                    <div class="bg-white/5 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-8 border border-white/10">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>

                    <h3 class="font-sans font-black italic tracking-tighter text-4xl text-gray-300 mb-3">
                        Admin
                    </h3>

                    <p class="text-gray-400 text-sm leading-relaxed px-4">
                        Manage resident database, process document requests, handle complaints, and update facilities.
                    </p>

                    <!-- EXPLANATION NOTE -->
                    <div class="mt-6 p-3 bg-red-500/20 border border-red-500/50 rounded-lg text-red-200 text-xs font-medium">
                        <i class="fa-solid fa-lock mr-1"></i> Admin registration is restricted. Contact the Brgy. Secretary or IT Admin to create an account.
                    </div>
                </div>
            }
            else
            {
                <!-- ACTIVE STATE (When Logging In) -->
                <a href="@routePrefix?role=admin" class="group relative bg-white/10 backdrop-blur-md border border-white/20 rounded-3xl p-10 text-center transition-all duration-300 hover:bg-[#C1E7FF] hover:scale-105 hover:shadow-[0_0_40px_rgba(193,231,255,0.3)] cursor-pointer">

                    <div class="absolute top-0 left-0 right-0 -mt-3 flex justify-center">
                        <span class="bg-[#2D7DA5] text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-widest shadow-lg group-hover:bg-[#003B5A] transition">
                            Administrative
                        </span>
                    </div>

                    <div class="bg-white/10 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-8 group-hover:bg-[#003B5A] transition duration-300 border border-white/10 group-hover:border-transparent">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-[#C1E7FF] group-hover:text-white transition duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>

                    <h3 class="font-sans font-black italic tracking-tighter text-4xl text-white mb-3 group-hover:text-[#003B5A] transition duration-300">
                        Admin
                    </h3>

                    <p class="text-[#C1E7FF]/70 text-sm leading-relaxed group-hover:text-[#003B5A]/80 transition duration-300 px-4">
                        Manage resident database, process document requests, handle complaints, and update facilities.
                    </p>

                    <div class="mt-6 inline-block border-b-2 border-[#C1E7FF]/30 group-hover:border-[#003B5A] pb-1 text-[#C1E7FF] group-hover:text-[#003B5A] text-xs font-bold uppercase tracking-wider transition">
                        Proceed &rarr;
                    </div>
                </a>
            }

        </div>

        <div class="mt-16 text-center">
            <a href="/" class="inline-flex items-center text-[#C1E7FF] hover:text-white text-sm font-bold transition duration-300 group">
                <span class="bg-white/10 p-2 rounded-full mr-3 group-hover:bg-white/20 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                </span>
                Back to Homepage
            </a>
        </div>
    </div>
</section>