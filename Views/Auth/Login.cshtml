@{
    ViewData["Title"] = "Login";
    string role = ViewBag.Role ?? "resident";
    string capitalizedRole = char.ToUpper(role[0]) + role.Substring(1);
    string labelText = role == "admin" ? "Admin ID or Username" : "Email Address";
    string placeholderText = role == "admin" ? "e.g. ad-0000 or admin_juan" : "e.g. juan@email.com";
    string buttonText = role == "admin" ? "Login as Admin" : "Login as Resident";
}

<section class="min-h-screen bg-[#F0F8FF] flex items-center justify-center p-4">

    <div class="bg-white rounded-2xl shadow-2xl overflow-hidden max-w-4xl w-full flex flex-col md:flex-row">

        <div class="w-full md:w-1/2 bg-[#003B5A] p-12 text-white flex flex-col justify-center relative overflow-hidden">
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-[#2D7DA5] rounded-full opacity-20"></div>
            <div class="absolute bottom-10 right-10 w-60 h-60 bg-[#C1E7FF] rounded-full opacity-10"></div>

            <div class="relative z-10">
                <h2 class="font-sans font-black italic tracking-tighter text-4xl mb-4">
                    Komu<span class="text-[#C1E7FF]">Nect</span>
                </h2>

                @if (role == "admin")
                {
                    <h3 class="text-xl font-bold mb-4">Official Admin Portal</h3>
                    <p class="text-[#C1E7FF]/80 text-sm leading-relaxed mb-8">
                        Secure access for barangay officials. Manage residents, process documents, and update community records.
                    </p>
                }
                else
                {
                    <h3 class="text-xl font-bold mb-4">Welcome Back, Ka-Barangay!</h3>
                    <p class="text-[#C1E7FF]/80 text-sm leading-relaxed mb-8">
                        Stay connected. Access services, request documents, and view updates in one centralized system.
                    </p>
                }

                <div class="text-xs font-bold uppercase tracking-widest opacity-50">
                    @capitalizedRole Access • Secure & Encrypted
                </div>
            </div>
        </div>

        <div class="w-full md:w-1/2 p-8 md:p-12 relative">

            <a href="/Auth/RoleSelection?action=login" class="absolute top-6 left-8 text-xs font-bold text-gray-400 hover:text-[#003B5A] flex items-center transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Switch Role
            </a>

            <div class="text-center mb-8 mt-4">
                <h2 class="text-[#003B5A] text-2xl font-bold">@capitalizedRole Login</h2>
                <p class="text-gray-400 text-sm mt-2">Please enter your @role credentials</p>

                <div asp-validation-summary="All" class="mt-4 p-3 bg-red-50 border border-red-200 text-red-600 rounded-lg text-sm font-bold shadow-sm empty:hidden"></div>
            </div>

            <form action="/Auth/Login" method="POST" class="space-y-5">
                <input type="hidden" name="Role" value="@role">
                @Html.AntiForgeryToken()

                <div>
                    <label class="block text-xs font-bold text-gray-500 mb-1">@labelText <span class="text-red-500">*</span></label>
                    <input name="LoginIdentifier" type="text" required placeholder="@placeholderText" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#003B5A] focus:ring-1 focus:ring-[#003B5A] outline-none transition">
                </div>

                <div>
                    <label class="block text-xs font-bold text-[#003B5A] uppercase mb-2">Password</label>
                    <div class="relative">
                        <input type="password" name="Password" id="loginPassword" required class="w-full px-4 py-3 pr-10 rounded-lg bg-gray-50 border border-gray-200 focus:border-[#003B5A] focus:ring-0 text-sm outline-none transition" placeholder="••••••••">
                        <button type="button" onclick="togglePassword('loginPassword', 'loginIcon')" class="absolute inset-y-0 right-0 px-3 flex items-center text-gray-400 hover:text-[#003B5A] focus:outline-none">
                            <svg id="loginIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-between text-xs text-gray-500">
                    <label class="flex items-center space-x-2 cursor-pointer">
                        <input type="checkbox" name="RememberMe" value="true" class="rounded text-[#003B5A] focus:ring-[#003B5A]">
                        <span>Remember me</span>
                    </label>
                    <a href="#" class="hover:text-[#003B5A] underline">Forgot Password?</a>
                </div>

                <button type="submit" class="w-full bg-[#003B5A] text-white font-bold py-3 rounded-lg shadow-lg hover:bg-[#2D7DA5] transition transform hover:-translate-y-0.5">
                    @buttonText
                </button>
            </form>

            <div class="mt-8 text-center text-xs text-gray-400">
                Don't have an account?
                <a href="/Auth/Signup?role=@role" class="text-[#003B5A] font-bold hover:underline">Register here</a>
            </div>
        </div>
    </div>
</section>

<script>
    function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);

        if (input.type === "password") {
            input.type = "text";
            icon.classList.add('text-[#003B5A]');
        } else {
            input.type = "password";
            icon.classList.remove('text-[#003B5A]');
        }
    }
</script>