@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KomuNect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-[#F0F8FF] font-sans antialiased text-gray-800">

    @if (Context.Session.GetInt32("AdminId").HasValue || Context.Session.GetInt32("ResidentId").HasValue)
    {
        <nav class="bg-white shadow-sm border-b border-gray-200 px-8 py-4 mb-6 flex justify-between items-center">

            <div class="text-xl font-black text-[#003B5A] tracking-tighter">
                Komu<span class="text-red-700">Nect</span>
            </div>

            <div class="flex gap-6 items-center">
                <a href="/Announcements/List" class="text-sm font-bold text-gray-500 hover:text-[#003B5A] transition">Announcements</a>
                <a href="/Complaints/List" class="text-sm font-bold text-gray-500 hover:text-[#003B5A] transition">Complaints</a>

                <span class="text-gray-300">|</span>

                <a href="/Auth/Logout" class="text-sm font-bold text-red-600 hover:text-red-800 transition">Log Out</a>
            </div>

        </nav>
    }

    <main role="main">
        @RenderBody()
    </main>

    <script src="//unpkg.com/alpinejs" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>